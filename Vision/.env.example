# Static Data Handling (Client-Side)
# ------------------------------------------------------------------------------
# Production Blob URL (set in Vercel dashboard):
# - 'false': Use local files in the 'public/data' folder (dev)
# - 'true': Use Vercel Blob storage (production)
NEXT_PUBLIC_USE_REMOTE_STATIC_DATA="true"
NEXT_PUBLIC_STATIC_API_URL="/data"

# Public Data API (Server-Side Only)
# ------------------------------------------------------------------------------
# Service key for apis.data.go.kr - used by Vercel API routes to fetch live bus data.
DATA_GO_KR_SERVICE_KEY="YOUR_KEY_HERE"

# Redis (Server-Side Only)
# ------------------------------------------------------------------------------
REDIS_URL="YOUR_REDIS_URL_HERE"

# Blob Storage (Server-Side Only)
# ------------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="YOUR_TOKEN_HERE"
