<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:id="@+id/widget_root"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="@drawable/bg_widget_home"
              android:orientation="vertical"
              android:padding="14dp">

    <Row xmlns:android="http://schemas.android.com/apk/res/android"
         android:layout_width="match_parent"
         android:layout_height="wrap_content">
        <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/widget_title"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:alpha="0.8"/>
    </Row>

    <TextView
            android:id="@+id/widget_route_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/widget_no_route"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"/>

    <TextView
            android:id="@+id/widget_departure_times"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:alpha="0.95"/>

    <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@android:color/white"
            android:alpha="0.2"/>

    <TextView
            android:id="@+id/widget_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="@string/widget_loading_location"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"/>

    <TextView
            android:id="@+id/widget_open_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_widget_home_button"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="@string/widget_open_app"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"/>

    <!-- Hidden field for route ID if needed for debugging/reference -->
    <TextView
            android:id="@+id/widget_route_id"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

</LinearLayout>
